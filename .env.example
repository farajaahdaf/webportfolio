# Authentication
AUTH_SECRET=replace-with-a-long-random-string-at-least-32-chars
ADMIN_EMAIL=replace-with-admin-email
ADMIN_PASSWORD=replace-with-strong-admin-password

# Supabase transaction pooler (server only)
DATABASE_URL=postgresql://postgres.project-ref:password@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=verify-full
CONTACT_WRITES_ENABLED=false

# Supabase Storage uploads (service role, server only)
SUPABASE_URL=https://project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key

# Public Site URL
NEXT_PUBLIC_SITE_URL=https://your-domain.example
